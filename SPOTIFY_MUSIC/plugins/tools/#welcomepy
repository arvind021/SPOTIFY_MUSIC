@app.on_message(filters.command("welcome") & ~filters.private)
async def auto_state(_, message):
    usage = "**бҙңsбҙҖЙўбҙҮ:**\n**вҰҝ /welcome [on|off]**"
    if len(message.command) == 1:
        return await message.reply_text(usage)
    
    chat_id = message.chat.id
    user = await app.get_chat_member(message.chat.id, message.from_user.id)
    
    if user.status in (
        enums.ChatMemberStatus.ADMINISTRATOR,
        enums.ChatMemberStatus.OWNER,
    ):
        A = await wlcm.find_one(chat_id)
        state = message.text.split(None, 1)[1].strip().lower()
        
        if state == "off":
            if A:
                await message.reply_text("**бҙЎбҙҮКҹбҙ„бҙҸбҙҚбҙҮ ЙҙбҙҸбҙӣЙӘТ“ЙӘбҙ„бҙҖбҙӣЙӘбҙҸЙҙ бҙҖКҹКҖбҙҮбҙҖбҙ…КҸ бҙ…ЙӘsбҙҖКҷКҹбҙҮбҙ… !**")
            else:
                await wlcm.add_wlcm(chat_id)
                await message.reply_text(f"**бҙ…ЙӘsбҙҖКҷКҹбҙҮбҙ… бҙЎбҙҮКҹбҙ„бҙҸбҙҚбҙҮ ЙҙбҙҸбҙӣЙӘТ“ЙӘбҙ„бҙҖбҙӣЙӘбҙҸЙҙ ЙӘЙҙ** {message.chat.title}")
        
        elif state == "on":
            if not A:
                await wlcm.add_wlcm(chat_id)  # Corrected from rm_wlcm to add_wlcm for "on"
                await message.reply_text(f"**бҙҮЙҙбҙҖКҷКҹбҙҮбҙ… бҙЎбҙҮКҹбҙ„бҙҸбҙҚбҙҮ ЙҙбҙҸбҙӣЙӘТ“ЙӘбҙ„бҙҖбҙӣЙӘбҙҸЙҙ ЙӘЙҙ** {message.chat.title}")
        else:
            await message.reply_text(usage)
    else:
        await message.reply("**sбҙҸКҖКҖКҸ бҙҸЙҙКҹКҸ бҙҖбҙ…бҙҚЙӘЙҙs бҙ„бҙҖЙҙ бҙҮЙҙбҙҖКҷКҹбҙҮ бҙЎбҙҮКҹбҙ„бҙҸбҙҚбҙҮ ЙҙбҙҸбҙӣЙӘТ“ЙӘбҙ„бҙҖбҙӣЙӘбҙҸЙҙ!**")

@app.on_chat_member_updated(filters.group, group=-3)
async def greet_new_member(_, member: ChatMemberUpdated):
    chat_id = member.chat.id
    count = await app.get_chat_members_count(chat_id)
    A = await wlcm.find_one(chat_id)

    # If the welcome message is disabled for the chat, do nothing
    if A:
        return

    user = None
    if member.new_chat_member:
        user = member.new_chat_member.user
    elif member.old_chat_member:
        user = member.old_chat_member.user
    
    if not user:
        return  # Exit if no user found in the update
    
    try:
        # Welcome message
        welcome_message = f"рҹ‘Ӣ {user.first_name}, WбҙҮКҹбҙ„бҙҸбҙҚбҙҮ TбҙҸ {member.chat.title}!\n\n" \
                          "вҖў I HбҙҸбҙҳбҙҮ YбҙҸбҙң AКҖбҙҮ FЙӘЙҙбҙҮ!\n\n" \
                          "вҖў PКҹбҙҮбҙҖsбҙҮ AКҹбҙЎбҙҖКҸs FбҙҸКҹКҹбҙҸбҙЎ TКңбҙҮ GКҖбҙҸбҙңбҙҳ RбҙңКҹбҙҮs!\n" \
                          "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n" \
                          f"бҙӣ бҙҸ бҙӣ бҙҖ Кҹ бҙҚ бҙҮ бҙҚ Кҷ бҙҮ КҖ: {count}\n" \
                          "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"
        
        # Creating an inline button to "Join рҹ‘Ӣ" with the link
        keyboard = InlineKeyboardMarkup(
            [[InlineKeyboardButton("Join рҹ‘Ӣ", url="https://t.me/+gF7M1_0PC803ZjU9")]]
        )

        # Send the welcome message with the inline button
        await app.send_message(chat_id, welcome_message, reply_markup=keyboard)
    except Exception as e:
